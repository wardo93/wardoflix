# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# WardoFlix build artifacts + runtime data + secrets
release/
cache/
.env
.env.*
!.env.example
.claude/

# Ad-hoc debug scripts that sometimes get created during investigation.
# If you write a real test, put it under test/ and git-add it explicitly.
test-*.js
debug-*.js
scratch-*.js

# Local notes that contain secrets (PATs, tokens, passwords). The
# "publish code.txt" file sitting in this directory holds a GitHub PAT
# used by electron-builder — never commit it. Any plausible filename
# that looks like a credential stash is excluded here defensively.
publish*.txt
*token*.txt
*secret*.txt
notes.txt
TODO.txt

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
